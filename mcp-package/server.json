{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.nyuchi/mukoko-news",
  "title": "Mukoko News",
  "description": "Pan-African news aggregation covering Zimbabwe and 15 other African countries. Search articles, browse trending topics, find similar stories, and filter by tag, author, or source.",
  "version": "1.0.0",
  "websiteUrl": "https://news.mukoko.com",
  "repository": {
    "url": "https://github.com/nyuchi/mukoko-news",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@nyuchi/mukoko-news-mcp",
      "version": "1.0.0",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "transportType": "http",
      "url": "https://news.mukoko.com/mcp"
    }
  ]
}
