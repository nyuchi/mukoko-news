# Mukoko News Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is in .gitignore and will not be committed.

# API Configuration
NEXT_PUBLIC_API_URL=https://mukoko-news-api.fly.dev

# API Secret - authenticates Next.js frontend to Fly.io backend
# Must match the API_SECRET set via: fly secrets set API_SECRET=your-secret
API_SECRET=your_api_secret_here
