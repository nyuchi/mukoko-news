# Mukoko News Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is in .gitignore and will not be committed.

# ── Base URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://news.mukoko.com

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Next.js Route Handlers read/write directly from MongoDB (not the Cloudflare Worker)
MONGODB_URI=mongodb+srv://<user>:<pass>@nyuchi-platform-doc-db.ge8d8qi.mongodb.net/?appName=nyuchi-platform-doc-db
MONGODB_DATABASE=news

# ── WorkOS AuthKit ────────────────────────────────────────────────────────────
# Two separate WorkOS OAuth applications:
#
# 1. Web AuthKit — inline sign-in (WorkOS Magic Auth, passwordless email code).
#    No hosted-UI redirect; the user stays on news.mukoko.com.
WORKOS_CLIENT_ID=client_01KV2G41CHGBSH6HG57AQBFKDD
# Required for inline Magic Auth (createMagicAuth / authenticateWithMagicAuth)
# and for the /admin gateway calls. From WorkOS dashboard → API Keys.
WORKOS_API_KEY=sk_live_your_workos_api_key
# Must match the Redirect URI registered on the web app in the WorkOS dashboard
WORKOS_REDIRECT_URI=https://news.mukoko.com/auth/callback
# 32+ character random string for encrypting session cookies
# Generate: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your_32_plus_char_random_cookie_password
# WorkOS org id for the `platform-team` org → admin/staff access to /admin
WORKOS_PLATFORM_ORG_ID=org_your_platform_team_org_id
#
# 2. MCP OAuth — PKCE public client for AI agents / Claude Desktop
#    Auth domain: https://identity.nyuchi.com  (no secret required)
WORKOS_MCP_CLIENT_ID=client_01KV2GGE5A7WRSFPWZ5HQJ3FNZ

# ── Cloudflare Worker API ─────────────────────────────────────────────────────
# Leave empty — Next.js Route Handlers serve all reads from MongoDB.
# Set only for the external widget/MCP API.
NEXT_PUBLIC_API_URL=

# API Secret — authenticates server-side Next.js to the Cloudflare Worker backend.
# Must match: cd backend && npx wrangler secret put API_SECRET
API_SECRET=your_api_secret_here

# ── Cloudflare (for backend deployment) ───────────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id

