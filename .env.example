# Mukoko News — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# ── Base URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://news.mukoko.com

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Server Actions read/write directly from MongoDB Atlas (no gateway Worker involved).
MONGODB_URI=mongodb+srv://<user>:<pass>@nyuchi-platform-doc-db.ge8d8qi.mongodb.net/?appName=nyuchi-platform-doc-db
MONGODB_DATABASE=news

# ── WorkOS AuthKit ────────────────────────────────────────────────────────────
# Web AuthKit — inline sign-in on news.mukoko.com (no external redirect).
WORKOS_CLIENT_ID=client_01KV2G41CHGBSH6HG57AQBFKDD
# From WorkOS dashboard → API Keys
WORKOS_API_KEY=sk_live_your_workos_api_key
# Must match the Redirect URI registered in WorkOS dashboard
WORKOS_REDIRECT_URI=https://news.mukoko.com/auth/callback
# 32+ character random string for encrypting session cookies
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your_32_plus_char_random_cookie_password
# WorkOS org for platform-team access to /admin
WORKOS_PLATFORM_ORG_ID=org_your_platform_team_org_id

# ── External API (widget/resale only) ─────────────────────────────────────────
# Leave empty — all page reads go through MongoDB Server Actions.
# Set this only if building the embed widget against an external API.
NEXT_PUBLIC_API_URL=

# ── Gateway Worker (admin mutations only) ─────────────────────────────────────
# The gateway Worker handles admin writes; reads never touch it.
GATEWAY_API_URL=https://news.mukoko.com

# ── Pipeline trigger ──────────────────────────────────────────────────────────
# URL of the Fly.io pipeline worker (for the manual refresh action).
FLY_WORKER_URL=https://news-ingestion.fly-worker.nyuchi.dev
# Bearer token for POST /trigger/collect — must match FLY_TRIGGER_TOKEN fly secret.
FLY_TRIGGER_TOKEN=your_fly_trigger_token_here
