# Mukoko News Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is in .gitignore and will not be committed.

# ── Base URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://news.mukoko.com

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Next.js Route Handlers read/write directly from MongoDB (not the Cloudflare Worker)
MONGODB_URI=mongodb+srv://<user>:<pass>@nyuchi-platform-doc-db.ge8d8qi.mongodb.net/?appName=nyuchi-platform-doc-db
MONGODB_DATABASE=news

# ── WorkOS AuthKit ────────────────────────────────────────────────────────────
# Public OAuth client (PKCE) — no client secret required.
# Auth domain: https://identity.nyuchi.com
WORKOS_CLIENT_ID=client_01KV2GGE5A7WRSFPWZ5HQJ3FNZ
# WORKOS_API_KEY only needed if using WorkOS Admin SDK (not required for PKCE auth)
# WORKOS_API_KEY=sk_live_...
# 32+ character random string for encrypting session cookies
# Generate: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your_32_plus_char_random_cookie_password

# ── Cloudflare Worker API ─────────────────────────────────────────────────────
# Leave empty — Next.js Route Handlers serve all reads from MongoDB.
# Set only for the external widget/MCP API.
NEXT_PUBLIC_API_URL=

# API Secret — authenticates server-side Next.js to the Cloudflare Worker backend.
# Must match: cd backend && npx wrangler secret put API_SECRET
API_SECRET=your_api_secret_here

# ── Cloudflare (for backend deployment) ───────────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id

