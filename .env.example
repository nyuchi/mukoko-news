# Mukoko News Console — Environment Variables (Next.js frontend)
# Copy this file to .env.local and fill in the values.
# .env.local is in .gitignore and will not be committed.
# For backend (Fly.io) env vars, see fly-worker/.env.example

# API Configuration — Fly.io backend
NEXT_PUBLIC_API_URL=https://mukoko-news-api.fly.dev

# Server-side API auth (must match fly secrets API_SECRET)
API_SECRET=your_api_secret_here

# Base URL for SEO/schema.org (optional, defaults to production)
# NEXT_PUBLIC_BASE_URL=https://news.mukoko.com
