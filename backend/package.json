  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250425.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.55.0"
  }
}
