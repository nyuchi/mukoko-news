# Mukoko News Pipeline — Environment Variables
# This is a data pipeline only — no user auth.
# Set via: flyctl secrets set KEY=VALUE -a mukoko-news

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@nyuchi-platform-doc-db.ge8d8qi.mongodb.net/?appName=nyuchi-platform-doc-db

# ── Newsdata.io ───────────────────────────────────────────────────────────────
NEWSDATA_API_KEY=pub_your_newsdata_api_key

# ── AI services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare Workers AI — BGE-M3 embeddings ────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_AI_API_TOKEN=your-cf-ai-api-token

# ── Gateway (Cloudflare Worker) ───────────────────────────────────────────────
GATEWAY_URL=https://news.mukoko.com
# API_SECRET for fundi-news-enrichment → gateway authenticated calls
# Must match: cd backend && npx wrangler secret put API_SECRET
GATEWAY_INTERNAL_TOKEN=your_api_secret_here

# ── fundi-news-enrichment (Cloudflare Worker) ─────────────────────────────────
FUNDI_ENRICHMENT_URL=https://fundi-news-enrichment.workers.dev
FUNDI_ENRICHMENT_TOKEN=your_enrichment_token_here

# ── On-demand trigger ─────────────────────────────────────────────────────────
# Bearer token protecting POST /trigger/collect (called by Next.js pull-to-refresh)
# Must match FLY_TRIGGER_TOKEN in Next.js .env.local
# Generate: openssl rand -hex 32
FLY_TRIGGER_TOKEN=your_fly_trigger_token_here

# ── Worker runtime ────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENVIRONMENT=production
