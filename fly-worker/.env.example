# Mukoko News Pipeline — Environment Variables
# This is a data pipeline only — no user auth, no public API.
# Set via: fly secrets set KEY=VALUE -a mukoko-news-api

# MongoDB — primary data store (source of truth)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=nyuchi-platform-doc-db
MONGODB_DATABASE=mukoko_news

# AI enrichment
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Workers AI — embeddings (optional)
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_AI_API_TOKEN=your-cf-ai-api-token

# Worker
LOG_LEVEL=info
ENVIRONMENT=production
